<?xml version="1.0" encoding="utf-8"?>
<!--
  Mythara TACTICAL — Watch Face Format.

  INTERACTIVE: pure-black field with a faint Mythara star emblem behind
  everything, a 12-tick tactical bezel, a top stat band (weather +
  temperature °F + battery + steps), three colour-coded world clocks
  laid out to match the map — LA left / CHI (device-local) centre with
  a glowing neon "now" dot / DEL right — a Casio-style dotted world
  map flanked by sun/moon markers showing which hemisphere is in day
  vs night, a live agent-message line (the latest Mythara chat message,
  pushed from the phone), a Mythara-gradient pulsing push-to-talk
  triangle, and a golden dot orbiting the dial as the seconds hand.

  ALWAYS-ON (ambient / power-save): everything above is hidden; the
  display collapses to a SINGLE dot-matrix line — the device's current
  time + "MYTHARA". Minimal lit pixels for burn-in / battery.

  Resource-only; the Wear OS renderer draws everything. <Image> assets
  are raster PNGs. Validated against WFF format version 2.
-->
<WatchFace width="450" height="450">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <!-- Dot-matrix bitmap font — 5x7 cells, digits + ':' + M Y T H A R. -->
    <BitmapFonts>
        <BitmapFont name="dotmatrix">
            <Character name="0" resource="dm_0" width="30" height="42" />
            <Character name="1" resource="dm_1" width="30" height="42" />
            <Character name="2" resource="dm_2" width="30" height="42" />
            <Character name="3" resource="dm_3" width="30" height="42" />
            <Character name="4" resource="dm_4" width="30" height="42" />
            <Character name="5" resource="dm_5" width="30" height="42" />
            <Character name="6" resource="dm_6" width="30" height="42" />
            <Character name="7" resource="dm_7" width="30" height="42" />
            <Character name="8" resource="dm_8" width="30" height="42" />
            <Character name="9" resource="dm_9" width="30" height="42" />
            <Character name=":" resource="dm_colon" width="30" height="42" />
            <Character name="M" resource="dm_m" width="30" height="42" />
            <Character name="Y" resource="dm_y" width="30" height="42" />
            <Character name="T" resource="dm_t" width="30" height="42" />
            <Character name="H" resource="dm_h" width="30" height="42" />
            <Character name="A" resource="dm_a" width="30" height="42" />
            <Character name="R" resource="dm_r" width="30" height="42" />
        </BitmapFont>
    </BitmapFonts>

    <Scene backgroundColor="#ff000000">

        <!-- ============ INTERACTIVE — full tactical face ============ -->
        <!-- Everything in this block hides (alpha 0) in ambient. -->

        <!-- Mythara star — faint emblem behind everything. -->
        <PartImage x="30" y="30" width="390" height="390">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Image resource="mythara_star" />
        </PartImage>

        <!-- 12-tick tactical bezel + HUD corner brackets. -->
        <PartImage x="0" y="0" width="450" height="450">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Image resource="tactical_bezel" />
        </PartImage>

        <!-- Blue glowing "north" dot at 12 o'clock — shown in BOTH modes. -->
        <Group x="0" y="0" width="450" height="450" name="north_dot">
            <PartDraw x="217" y="2" width="16" height="16">
                <Ellipse x="0" y="0" width="16" height="16"><Fill color="#553d9cff" /></Ellipse>
                <Ellipse x="3" y="3" width="10" height="10"><Fill color="#ff3d9cff" /></Ellipse>
                <Ellipse x="5" y="5" width="6" height="6"><Fill color="#ffd6f0ff" /></Ellipse>
            </PartDraw>
        </Group>

        <!-- ===== TOP STAT BAND — weather + temp °F + battery + steps ===== -->
        <Group x="0" y="0" width="450" height="450" name="topband">
            <Variant mode="AMBIENT" target="alpha" value="0" />

            <!-- weather condition icon (top centre) — one Condition per
                 grouped WEATHER.CONDITION code. -->
            <Condition>
                <Expressions>
                    <Expression name="wx_clear_day">[WEATHER.IS_AVAILABLE] &amp;&amp; ([WEATHER.CONDITION] == 1 || [WEATHER.CONDITION] == 8) &amp;&amp; [WEATHER.IS_DAY]</Expression>
                </Expressions>
                <Compare expression="wx_clear_day">
                    <PartImage x="80" y="58" width="28" height="28"><Image resource="wx_sun" /></PartImage>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="wx_clear_night">[WEATHER.IS_AVAILABLE] &amp;&amp; ([WEATHER.CONDITION] == 1 || [WEATHER.CONDITION] == 8) &amp;&amp; ![WEATHER.IS_DAY]</Expression>
                </Expressions>
                <Compare expression="wx_clear_night">
                    <PartImage x="80" y="58" width="28" height="28"><Image resource="wx_moon" /></PartImage>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="wx_cloud">[WEATHER.IS_AVAILABLE] &amp;&amp; ([WEATHER.CONDITION] == 2 || [WEATHER.CONDITION] == 14)</Expression>
                </Expressions>
                <Compare expression="wx_cloud">
                    <PartImage x="80" y="58" width="28" height="28"><Image resource="wx_cloud" /></PartImage>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="wx_fog">[WEATHER.IS_AVAILABLE] &amp;&amp; ([WEATHER.CONDITION] == 3 || [WEATHER.CONDITION] == 13)</Expression>
                </Expressions>
                <Compare expression="wx_fog">
                    <PartImage x="80" y="58" width="28" height="28"><Image resource="wx_fog" /></PartImage>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="wx_rain">[WEATHER.IS_AVAILABLE] &amp;&amp; ([WEATHER.CONDITION] == 4 || [WEATHER.CONDITION] == 6 || [WEATHER.CONDITION] == 12)</Expression>
                </Expressions>
                <Compare expression="wx_rain">
                    <PartImage x="80" y="58" width="28" height="28"><Image resource="wx_rain" /></PartImage>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="wx_snow">[WEATHER.IS_AVAILABLE] &amp;&amp; ([WEATHER.CONDITION] == 5 || [WEATHER.CONDITION] == 7 || [WEATHER.CONDITION] == 10 || [WEATHER.CONDITION] == 11)</Expression>
                </Expressions>
                <Compare expression="wx_snow">
                    <PartImage x="80" y="58" width="28" height="28"><Image resource="wx_snow" /></PartImage>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="wx_storm">[WEATHER.IS_AVAILABLE] &amp;&amp; [WEATHER.CONDITION] == 9</Expression>
                </Expressions>
                <Compare expression="wx_storm">
                    <PartImage x="80" y="58" width="28" height="28"><Image resource="wx_storm" /></PartImage>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="wx_wind">[WEATHER.IS_AVAILABLE] &amp;&amp; [WEATHER.CONDITION] == 15</Expression>
                </Expressions>
                <Compare expression="wx_wind">
                    <PartImage x="80" y="58" width="28" height="28"><Image resource="wx_wind" /></PartImage>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="wx_na">![WEATHER.IS_AVAILABLE] || [WEATHER.CONDITION] == 0</Expression>
                </Expressions>
                <Compare expression="wx_na">
                    <PartImage x="80" y="58" width="28" height="28"><Image resource="wx_na" /></PartImage>
                </Compare>
            </Condition>

            <!-- stat row: weather temp °F · watch battery · phone battery.
                 Temperature converts to Fahrenheit when the platform unit
                 is Celsius (TEMPERATURE_UNIT 1 = C, 2 = F). -->
            <Condition>
                <Expressions>
                    <Expression name="t_f">[WEATHER.IS_AVAILABLE] &amp;&amp; [WEATHER.TEMPERATURE_UNIT] == 2</Expression>
                </Expressions>
                <Compare expression="t_f">
                    <PartText x="110" y="59" width="56" height="24">
                        <Text align="START">
                            <Font family="jetbrains_mono_regular" size="17" color="#ff68ffd6">
                                <Template><![CDATA[%d°F]]><Parameter expression="[WEATHER.TEMPERATURE]" /></Template>
                            </Font>
                        </Text>
                    </PartText>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="t_c">[WEATHER.IS_AVAILABLE] &amp;&amp; [WEATHER.TEMPERATURE_UNIT] != 2</Expression>
                </Expressions>
                <Compare expression="t_c">
                    <PartText x="110" y="59" width="56" height="24">
                        <Text align="START">
                            <Font family="jetbrains_mono_regular" size="17" color="#ff68ffd6">
                                <Template><![CDATA[%d°F]]><Parameter expression="[WEATHER.TEMPERATURE] * 9 / 5 + 32" /></Template>
                            </Font>
                        </Text>
                    </PartText>
                </Compare>
            </Condition>

            <!-- watch battery icon — the value is a ComplicationSlot below -->
            <PartImage x="180" y="61" width="22" height="22"><Image resource="ic_batt" /></PartImage>

            <!-- phone battery icon — the value is a ComplicationSlot below -->
            <PartImage x="278" y="61" width="22" height="22"><Image resource="ic_phone" /></PartImage>
        </Group>

        <!-- Phone battery value — ComplicationSlot (direct Scene child) fed
             by the :wear PhoneBatteryComplicationService, which the phone
             refreshes over the Data Layer with its own battery level.
             Hidden in ambient via the inner PartText's Variant. -->
        <ComplicationSlot slotId="2" x="300" y="57" width="76" height="30"
            supportedTypes="SHORT_TEXT EMPTY">
            <BoundingOval x="0" y="0" width="76" height="30" />
            <DefaultProviderPolicy
                primaryProvider="com.mythara.debug/com.mythara.wear.complications.PhoneBatteryComplicationService"
                primaryProviderType="SHORT_TEXT"
                defaultSystemProvider="WATCH_BATTERY"
                defaultSystemProviderType="SHORT_TEXT" />
            <Complication type="SHORT_TEXT">
                <PartText x="0" y="0" width="76" height="30">
                    <Variant mode="AMBIENT" target="alpha" value="0" />
                    <Text align="START">
                        <Font family="jetbrains_mono_regular" size="17" color="#ff3d9cff">
                            <Template><![CDATA[%s]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <!-- Watch battery — configurable ComplicationSlot. Defaults to the
             system WATCH_BATTERY provider so it shows the watch's own
             battery out of the box, but long-pressing the face lets the
             user re-point it (steps, heart rate, date, …) without
             disturbing the rest of the tactical layout. -->
        <ComplicationSlot slotId="3" x="204" y="57" width="76" height="30"
            supportedTypes="SHORT_TEXT EMPTY">
            <BoundingOval x="0" y="0" width="76" height="30" />
            <DefaultProviderPolicy
                defaultSystemProvider="WATCH_BATTERY"
                defaultSystemProviderType="SHORT_TEXT" />
            <Complication type="SHORT_TEXT">
                <PartText x="0" y="0" width="76" height="30">
                    <Variant mode="AMBIENT" target="alpha" value="0" />
                    <Text align="START">
                        <Font family="jetbrains_mono_regular" size="17" color="#ff39ff7a">
                            <Template><![CDATA[%s]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <!-- ===== Three world clocks — laid out to match the map =====
             LA (amber) left · CHI (device-local, blue) centre with a
             glowing neon "now" dot · DEL (green) right. Hidden in ambient. -->
        <Group x="0" y="0" width="450" height="450" name="clocks">
            <Variant mode="AMBIENT" target="alpha" value="0" />

            <!-- left — LA / US Pacific (Americas side of the map) -->
            <PartText x="6" y="106" width="132" height="20">
                <Text align="CENTER">
                    <Font family="jetbrains_mono_regular" size="16" color="#ffffb000"><![CDATA[LA]]></Font>
                </Text>
            </PartText>
            <DigitalClock x="6" y="138" width="132" height="40">
                <Localization timeZone="America/Los_Angeles" />
                <TimeText format="hh:mm" hourFormat="24" align="CENTER" x="0" y="0" width="132" height="40">
                    <Font family="SYNC_TO_DEVICE" size="26" weight="NORMAL" slant="NORMAL" color="#ffffb000" />
                </TimeText>
            </DigitalClock>

            <!-- centre — CHI / device-local (the "now" clock) -->
            <PartText x="150" y="100" width="150" height="20">
                <Text align="CENTER">
                    <Font family="jetbrains_mono_regular" size="17" color="#ff3d9cff"><![CDATA[CHI]]></Font>
                </Text>
            </PartText>
            <!-- glowing neon "now" dot, centred, marking the current clock -->
            <PartDraw x="219" y="121" width="12" height="12">
                <Ellipse x="0" y="0" width="12" height="12"><Fill color="#553d9cff" /></Ellipse>
                <Ellipse x="2" y="2" width="8" height="8"><Fill color="#ff3d9cff" /></Ellipse>
                <Ellipse x="4" y="4" width="4" height="4"><Fill color="#ffd6f0ff" /></Ellipse>
            </PartDraw>
            <DigitalClock x="150" y="135" width="150" height="46">
                <TimeText format="hh:mm" hourFormat="24" align="CENTER" x="0" y="0" width="150" height="46">
                    <Font family="SYNC_TO_DEVICE" size="33" weight="NORMAL" slant="NORMAL" color="#ff3d9cff" />
                </TimeText>
            </DigitalClock>

            <!-- right — DEL / India (Asia side of the map) -->
            <PartText x="312" y="106" width="132" height="20">
                <Text align="CENTER">
                    <Font family="jetbrains_mono_regular" size="16" color="#ff39ff7a"><![CDATA[DEL]]></Font>
                </Text>
            </PartText>
            <DigitalClock x="312" y="138" width="132" height="40">
                <Localization timeZone="Asia/Kolkata" />
                <TimeText format="hh:mm" hourFormat="24" align="CENTER" x="0" y="0" width="132" height="40">
                    <Font family="SYNC_TO_DEVICE" size="26" weight="NORMAL" slant="NORMAL" color="#ff39ff7a" />
                </TimeText>
            </DigitalClock>
        </Group>

        <!-- Casio-style dotted world map -->
        <PartImage x="120" y="186" width="210" height="92">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Image resource="world_map" />
        </PartImage>

        <!-- ===== Day/night terminator line over the world map =====
             A thin yellow curve showing where sunlight falls. Twelve
             pre-rendered frames (one per 2h of UTC) swapped by UTC hour;
             the curve shape is the current season's, the sweep is live.
             Hidden in ambient. -->
        <Group x="0" y="0" width="450" height="450" name="terminator">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <Condition>
                <Expressions><Expression name="tf0">(([UTC_TIMESTAMP] / 3600000) % 24) &lt; 2</Expression></Expressions>
                <Compare expression="tf0"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_0" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf1">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 2 &amp;&amp; (([UTC_TIMESTAMP] / 3600000) % 24) &lt; 4</Expression></Expressions>
                <Compare expression="tf1"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_1" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf2">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 4 &amp;&amp; (([UTC_TIMESTAMP] / 3600000) % 24) &lt; 6</Expression></Expressions>
                <Compare expression="tf2"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_2" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf3">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 6 &amp;&amp; (([UTC_TIMESTAMP] / 3600000) % 24) &lt; 8</Expression></Expressions>
                <Compare expression="tf3"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_3" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf4">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 8 &amp;&amp; (([UTC_TIMESTAMP] / 3600000) % 24) &lt; 10</Expression></Expressions>
                <Compare expression="tf4"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_4" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf5">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 10 &amp;&amp; (([UTC_TIMESTAMP] / 3600000) % 24) &lt; 12</Expression></Expressions>
                <Compare expression="tf5"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_5" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf6">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 12 &amp;&amp; (([UTC_TIMESTAMP] / 3600000) % 24) &lt; 14</Expression></Expressions>
                <Compare expression="tf6"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_6" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf7">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 14 &amp;&amp; (([UTC_TIMESTAMP] / 3600000) % 24) &lt; 16</Expression></Expressions>
                <Compare expression="tf7"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_7" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf8">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 16 &amp;&amp; (([UTC_TIMESTAMP] / 3600000) % 24) &lt; 18</Expression></Expressions>
                <Compare expression="tf8"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_8" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf9">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 18 &amp;&amp; (([UTC_TIMESTAMP] / 3600000) % 24) &lt; 20</Expression></Expressions>
                <Compare expression="tf9"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_9" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf10">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 20 &amp;&amp; (([UTC_TIMESTAMP] / 3600000) % 24) &lt; 22</Expression></Expressions>
                <Compare expression="tf10"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_10" /></PartImage></Compare>
            </Condition>
            <Condition>
                <Expressions><Expression name="tf11">(([UTC_TIMESTAMP] / 3600000) % 24) &gt;= 22</Expression></Expressions>
                <Compare expression="tf11"><PartImage x="120" y="186" width="210" height="92"><Image resource="term_11" /></PartImage></Compare>
            </Condition>
        </Group>

        <!-- ===== Day / night markers flanking the map =====
             Left marker tracks the Americas side (LA hour ≈ device-CHI
             − 2h); right marker tracks the Asia side (DEL hour ≈
             device-CHI + 11h). Sun when that hemisphere is in daylight
             (06:00–18:00 local), moon otherwise. Hidden in ambient. -->
        <Group x="0" y="0" width="450" height="450" name="daynight">
            <Variant mode="AMBIENT" target="alpha" value="0" />

            <!-- left — LA / Americas -->
            <Condition>
                <Expressions>
                    <Expression name="la_day">(([HOUR_0_23] + 22) % 24) &gt;= 6 &amp;&amp; (([HOUR_0_23] + 22) % 24) &lt; 18</Expression>
                </Expressions>
                <Compare expression="la_day">
                    <PartImage x="40" y="208" width="48" height="48"><Image resource="wx_sun" /></PartImage>
                </Compare>
                <Default>
                    <PartImage x="40" y="208" width="48" height="48"><Image resource="wx_moon" /></PartImage>
                </Default>
            </Condition>

            <!-- right — DEL / Asia -->
            <Condition>
                <Expressions>
                    <Expression name="del_day">(([HOUR_0_23] + 11) % 24) &gt;= 6 &amp;&amp; (([HOUR_0_23] + 11) % 24) &lt; 18</Expression>
                </Expressions>
                <Compare expression="del_day">
                    <PartImage x="362" y="208" width="48" height="48"><Image resource="wx_sun" /></PartImage>
                </Compare>
                <Default>
                    <PartImage x="362" y="208" width="48" height="48"><Image resource="wx_moon" /></PartImage>
                </Default>
            </Condition>
        </Group>

        <!-- ===== REMINDER — two slots, both visible in active AND AOD =====
             Same two-line shape on every mode:
               slot 4 → countdown ("in 14 min") — bold static, always
                        in view, no scrolling
               slot 5 → title ("Gibraltar dry run") — marquee in active,
                        multi-line WRAP in AOD (separate PartText per
                        mode so the AOD render doesn't try to run an
                        animation, which AOD blocks anyway)
             A single ComplicationSlot can't carry two visually-
             distinct pieces (no WFF string-split), hence two slots
             pulling from two complication services. -->

        <!-- Countdown — bold orange, static, always in view in BOTH
             modes. No Variant alpha=0 anywhere; renders identically
             active + AOD since "in 14 min" is short and self-fits.
             Sits in the band right below the sun/moon (y=208-256)
             and above the title slot — no overlap with the AOD time
             (y=228-286 ambient time is hidden when this strip's
             reminder content is what we're showing instead, and the
             non-reminder ambient sequence simply doesn't overlap on
             pixels in the 263-285 strip). -->
        <ComplicationSlot slotId="4" x="55" y="263" width="340" height="22"
            supportedTypes="SHORT_TEXT LONG_TEXT EMPTY">
            <BoundingOval x="0" y="0" width="340" height="22" />
            <DefaultProviderPolicy
                primaryProvider="com.mythara.debug/com.mythara.wear.complications.ReminderCountdownComplicationService"
                primaryProviderType="SHORT_TEXT"
                defaultSystemProvider="WATCH_BATTERY"
                defaultSystemProviderType="SHORT_TEXT" />
            <Complication type="SHORT_TEXT">
                <PartText x="0" y="0" width="340" height="22">
                    <Text align="CENTER" maxLines="1">
                        <Font family="jetbrains_mono_regular" size="16" weight="BOLD" color="#ffffb000">
                            <Template><![CDATA[⏰ %s]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
            <Complication type="LONG_TEXT">
                <PartText x="0" y="0" width="340" height="22">
                    <Text align="CENTER" maxLines="1">
                        <Font family="jetbrains_mono_regular" size="16" weight="BOLD" color="#ffffb000">
                            <Template><![CDATA[⏰ %s]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <!-- Title — slot occupies a 48px band right under the
             countdown. In active mode the inner marquee renders the
             top 20px line; in AOD a separate static PartText wraps
             the title across up to 2 lines (font 13 ≈ 17px line
             height = ~34px content, fits in 48px slot). Two PartText
             siblings inside each Complication: marquee = active-only
             (alpha 0 in AOD), wrap = AOD-only (alpha 0 in active).
             Same complication text feeds both. Slot bbox no longer
             overlaps slot 1 (insight) or the PTT triangle. -->
        <ComplicationSlot slotId="5" x="20" y="287" width="410" height="48"
            supportedTypes="SHORT_TEXT LONG_TEXT EMPTY">
            <BoundingOval x="0" y="0" width="410" height="48" />
            <DefaultProviderPolicy
                primaryProvider="com.mythara.debug/com.mythara.wear.complications.ReminderTitleComplicationService"
                primaryProviderType="LONG_TEXT"
                defaultSystemProvider="WATCH_BATTERY"
                defaultSystemProviderType="SHORT_TEXT" />
            <Complication type="SHORT_TEXT">
                <!-- Active: marquee single-line at top of the band. -->
                <PartText x="0" y="0" width="900" height="20">
                    <Variant mode="AMBIENT" target="alpha" value="0" />
                    <Transform target="x" value="0 - (([SECOND] * 8) % 700)" />
                    <Text align="START" maxLines="1">
                        <Font family="jetbrains_mono_regular" size="13" color="#ffffb000">
                            <Template><![CDATA[%s]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                        </Font>
                    </Text>
                </PartText>
                <!-- AOD: wrap up to 2 lines, centered, fills the band
                     (no marquee — AOD blocks animation). Longer text
                     truncates; the active mode shows the full title
                     via marquee. -->
                <PartText x="0" y="0" width="410" height="48" alpha="0">
                    <Variant mode="AMBIENT" target="alpha" value="255" />
                    <Text align="CENTER" maxLines="2">
                        <Font family="jetbrains_mono_regular" size="13" color="#ffffb000">
                            <Template><![CDATA[%s]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
            <Complication type="LONG_TEXT">
                <PartText x="0" y="0" width="900" height="20">
                    <Variant mode="AMBIENT" target="alpha" value="0" />
                    <Transform target="x" value="0 - (([SECOND] * 8) % 700)" />
                    <Text align="START" maxLines="1">
                        <Font family="jetbrains_mono_regular" size="13" color="#ffffb000">
                            <Template><![CDATA[%s]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                        </Font>
                    </Text>
                </PartText>
                <PartText x="0" y="0" width="410" height="48" alpha="0">
                    <Variant mode="AMBIENT" target="alpha" value="255" />
                    <Text align="CENTER" maxLines="2">
                        <Font family="jetbrains_mono_regular" size="13" color="#ffffb000">
                            <Template><![CDATA[%s]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <!-- ===== AGENT MESSAGE — live line from Mythara =====
             ComplicationSlot fed by the :wear InsightComplicationService,
             which the phone refreshes over the Data Layer with the latest
             agent chat message (kept in sync with the app). Replaces the
             old hard-coded terminal line. Hidden in ambient. -->
        <ComplicationSlot slotId="1" x="55" y="337" width="340" height="22"
            supportedTypes="SHORT_TEXT LONG_TEXT EMPTY">
            <BoundingOval x="0" y="0" width="340" height="22" />
            <DefaultProviderPolicy
                primaryProvider="com.mythara.debug/com.mythara.wear.complications.InsightComplicationService"
                primaryProviderType="LONG_TEXT"
                defaultSystemProvider="WATCH_BATTERY"
                defaultSystemProviderType="SHORT_TEXT" />
            <!-- Bright neon-green terminal line — single-line marquee
                 sandwiched between the title slot and the PTT
                 triangle. A block cursor blinks every second for a
                 live typewriter feel (true per-char reveal isn't
                 expressible in WFF, so a blinking cursor stands in).
                 Two Conditions toggle the cursor glyph between "|"
                 and a same-width space so the marquee text doesn't
                 jitter; wrapped in a Group so the Complication child
                 set stays valid. Hidden entirely in AOD. -->
            <Complication type="SHORT_TEXT">
                <Group x="0" y="0" width="340" height="22" name="agent_short">
                    <Variant mode="AMBIENT" target="alpha" value="0" />
                    <Condition>
                        <Expressions>
                            <Expression name="agent_cursor_on_s">[SECOND] % 2 == 0</Expression>
                        </Expressions>
                        <Compare expression="agent_cursor_on_s">
                            <PartText x="0" y="0" width="900" height="22" alpha="255">
                                <Transform target="x" value="0 - (([SECOND] * 8) % 700)" />
                                <Text align="START" maxLines="1">
                                    <Font family="jetbrains_mono_regular" size="14" color="#ff39ff14">
                                        <Template><![CDATA[> %s|]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                                    </Font>
                                </Text>
                            </PartText>
                        </Compare>
                    </Condition>
                    <Condition>
                        <Expressions>
                            <Expression name="agent_cursor_off_s">[SECOND] % 2 == 1</Expression>
                        </Expressions>
                        <Compare expression="agent_cursor_off_s">
                            <PartText x="0" y="0" width="900" height="22" alpha="255">
                                <Transform target="x" value="0 - (([SECOND] * 8) % 700)" />
                                <Text align="START" maxLines="1">
                                    <Font family="jetbrains_mono_regular" size="14" color="#ff39ff14">
                                        <Template><![CDATA[> %s ]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                                    </Font>
                                </Text>
                            </PartText>
                        </Compare>
                    </Condition>
                </Group>
            </Complication>
            <Complication type="LONG_TEXT">
                <Group x="0" y="0" width="340" height="22" name="agent_long">
                    <Variant mode="AMBIENT" target="alpha" value="0" />
                    <Condition>
                        <Expressions>
                            <Expression name="agent_cursor_on_l">[SECOND] % 2 == 0</Expression>
                        </Expressions>
                        <Compare expression="agent_cursor_on_l">
                            <PartText x="0" y="0" width="900" height="22" alpha="255">
                                <Transform target="x" value="0 - (([SECOND] * 8) % 700)" />
                                <Text align="START" maxLines="1">
                                    <Font family="jetbrains_mono_regular" size="14" color="#ff39ff14">
                                        <Template><![CDATA[> %s|]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                                    </Font>
                                </Text>
                            </PartText>
                        </Compare>
                    </Condition>
                    <Condition>
                        <Expressions>
                            <Expression name="agent_cursor_off_l">[SECOND] % 2 == 1</Expression>
                        </Expressions>
                        <Compare expression="agent_cursor_off_l">
                            <PartText x="0" y="0" width="900" height="22" alpha="255">
                                <Transform target="x" value="0 - (([SECOND] * 8) % 700)" />
                                <Text align="START" maxLines="1">
                                    <Font family="jetbrains_mono_regular" size="14" color="#ff39ff14">
                                        <Template><![CDATA[> %s ]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                                    </Font>
                                </Text>
                            </PartText>
                        </Compare>
                    </Condition>
                </Group>
            </Complication>
            <Complication type="EMPTY" />
        </ComplicationSlot>

        <!-- ===== PTT — push-to-talk to the Mythara agent =====
             Tactical triangle that pulses in the Mythara gradient: a
             purple base with a cyan layer cross-fading over it. The
             Launch element makes it a tap target that opens the :wear
             PTT mic app. Hidden in ambient. -->
        <Group x="0" y="0" width="450" height="450" name="ptt">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <PartImage x="195" y="360" width="60" height="56">
                <Image resource="ptt_button" />
            </PartImage>
            <PartImage x="195" y="360" width="60" height="56">
                <Launch target="com.mythara.debug/com.mythara.wear.MainActivity" />
                <Transform target="alpha" value="[SECOND] % 2 == 0 ? 255 : 55">
                    <Animation duration="1" interpolation="EASE_IN_OUT" />
                </Transform>
                <Image resource="ptt_button_glow" />
            </PartImage>
        </Group>

        <!-- Glowing golden orbiting seconds indicator — shown in BOTH modes -->
        <AnalogClock x="0" y="0" width="450" height="450">
            <SecondHand resource="seconds_dot" x="203" y="20" width="44" height="205"
                pivotX="0.5" pivotY="1.0" />
        </AnalogClock>

        <!-- ============ ALWAYS-ON — two dot-matrix lines ============ -->
        <!-- Hidden interactive (alpha 0); shown in ambient. Power-save
             display is MYTHARA on one line and the device time on the
             line below, both dot-matrix, centred. A pair of rolodex-
             style glyph blocks flank MYTHARA, each cycling through 4
             colour/symbol variants every minute (the only animation
             AOD allows — the surface refreshes once per minute).
             Minimal extra lit pixels for burn-in / battery. -->
        <Group x="0" y="0" width="450" height="450" name="ambient" alpha="0">
            <Variant mode="AMBIENT" target="alpha" value="255" />

            <!-- MYTHARA wordmark — top line, dot-matrix, centred.
                 Colour and font intentionally unchanged. -->
            <PartText x="0" y="172" width="450" height="50">
                <Text align="CENTER">
                    <BitmapFont family="dotmatrix" size="30" color="#ff9be8c8"><![CDATA[MYTHARA]]></BitmapFont>
                </Text>
            </PartText>

            <!-- Left rolodex glyphs — 3 chars, right-aligned ending just
                 before MYTHARA's left edge. Cycles every minute through
                 4 (glyph, colour) variants stepping the linear-gradient
                 palette. -->
            <Condition>
                <Expressions>
                    <Expression name="rolo_l_a">([MINUTE] % 4) == 0</Expression>
                </Expressions>
                <Compare expression="rolo_l_a">
                    <PartText x="30" y="182" width="90" height="40">
                        <Text align="END">
                            <Font family="jetbrains_mono_regular" size="22" color="#ff68ffd6"><![CDATA[▓▒░]]></Font>
                        </Text>
                    </PartText>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="rolo_l_b">([MINUTE] % 4) == 1</Expression>
                </Expressions>
                <Compare expression="rolo_l_b">
                    <PartText x="30" y="182" width="90" height="40">
                        <Text align="END">
                            <Font family="jetbrains_mono_regular" size="22" color="#ff3d9cff"><![CDATA[◆◇◈]]></Font>
                        </Text>
                    </PartText>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="rolo_l_c">([MINUTE] % 4) == 2</Expression>
                </Expressions>
                <Compare expression="rolo_l_c">
                    <PartText x="30" y="182" width="90" height="40">
                        <Text align="END">
                            <Font family="jetbrains_mono_regular" size="22" color="#ffeb4268"><![CDATA[▶▷▸]]></Font>
                        </Text>
                    </PartText>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="rolo_l_d">([MINUTE] % 4) == 3</Expression>
                </Expressions>
                <Compare expression="rolo_l_d">
                    <PartText x="30" y="182" width="90" height="40">
                        <Text align="END">
                            <Font family="jetbrains_mono_regular" size="22" color="#ffffb000"><![CDATA[▣▢▤]]></Font>
                        </Text>
                    </PartText>
                </Compare>
            </Condition>

            <!-- Right rolodex glyphs — mirror of the left, offset by 2
                 in the cycle so the two sides aren't always the same
                 colour at the same time (more rolodex-y). -->
            <Condition>
                <Expressions>
                    <Expression name="rolo_r_a">(([MINUTE] + 2) % 4) == 0</Expression>
                </Expressions>
                <Compare expression="rolo_r_a">
                    <PartText x="330" y="182" width="90" height="40">
                        <Text align="START">
                            <Font family="jetbrains_mono_regular" size="22" color="#ff68ffd6"><![CDATA[░▒▓]]></Font>
                        </Text>
                    </PartText>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="rolo_r_b">(([MINUTE] + 2) % 4) == 1</Expression>
                </Expressions>
                <Compare expression="rolo_r_b">
                    <PartText x="330" y="182" width="90" height="40">
                        <Text align="START">
                            <Font family="jetbrains_mono_regular" size="22" color="#ff3d9cff"><![CDATA[◈◇◆]]></Font>
                        </Text>
                    </PartText>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="rolo_r_c">(([MINUTE] + 2) % 4) == 2</Expression>
                </Expressions>
                <Compare expression="rolo_r_c">
                    <PartText x="330" y="182" width="90" height="40">
                        <Text align="START">
                            <Font family="jetbrains_mono_regular" size="22" color="#ffeb4268"><![CDATA[◂◁◀]]></Font>
                        </Text>
                    </PartText>
                </Compare>
            </Condition>
            <Condition>
                <Expressions>
                    <Expression name="rolo_r_d">(([MINUTE] + 2) % 4) == 3</Expression>
                </Expressions>
                <Compare expression="rolo_r_d">
                    <PartText x="330" y="182" width="90" height="40">
                        <Text align="START">
                            <Font family="jetbrains_mono_regular" size="22" color="#ffffb000"><![CDATA[▤▢▣]]></Font>
                        </Text>
                    </PartText>
                </Compare>
            </Condition>

            <!-- device-local current time — line below, dot-matrix, centred -->
            <DigitalClock x="0" y="228" width="450" height="58">
                <TimeText format="hh:mm" hourFormat="24" align="CENTER" x="0" y="0" width="450" height="58">
                    <BitmapFont family="dotmatrix" size="30" color="#ff9be8c8" />
                </TimeText>
            </DigitalClock>
        </Group>

    </Scene>
</WatchFace>
