<?xml version="1.0" encoding="utf-8"?>
<!--
  VoiceInteractionService configuration. Required by Android for an
  app to be picked as the default Assistant and to receive the
  assist-class gestures (home long-press, corner-swipe assist, Pixel
  Buds touch-and-hold).

  - sessionService: the VoiceInteractionSessionService companion.
    A real Assistant would draw an overlay sheet here; Mythara
    immediately finishes the session and lets MainActivity (already
    running via ACTION_ASSIST) own the UI.

  - recognitionService: optional on Android 12+ — when omitted the
    system uses the default RecognitionService. We don't ship our
    own, so we don't declare one. Mythara's STT path uses
    SpeechRecognizer (which picks the device default) regardless.

  - supportsAssist: yes — Mythara handles `assist` invocations.
  - supportsLaunchFromKeyguard: yes — onLaunchVoiceAssistFromKeyguard
    in MytharaVoiceInteractionService launches MainActivity with
    ACTION_ASSIST so the existing handler picks it up.
-->
<voice-interaction-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:sessionService="com.mythara.voice.MytharaVoiceInteractionSessionService"
    android:supportsAssist="true" />
