<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Core capabilities (full set declared up-front; runtime prompts come later) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Start Mythara at device boot so the assistant is ready without
         the user having to launch the app first. The BootReceiver
         wakes the process; everything else (notification listener,
         accessibility, WorkManager schedules) auto-resumes from
         there. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Phone-control + communication (gated; require explicit user consent) -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />
    <!-- SMS read access for the one-time message-history import that
         builds the user's persona from their texting patterns. Play
         Store heavily restricts this for non-default SMS apps; we're
         sideload-only so the user just grants at runtime when they
         hit the Import button in Settings. -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Exact-alarm permissions for scheduled reminders. Android 12+
         requires SCHEDULE_EXACT_ALARM (revocable by the user via
         Settings); Android 13+ added USE_EXACT_ALARM as a static
         permission that grants the capability without the user being
         able to revoke it — appropriate for an assistant whose entire
         premise is "Lumi will remind me at X time". Both declared so
         the system picks the most-trusted granted variant at runtime.
         Without these, AlarmManager.setExactAndAllowWhileIdle silently
         downgrades to inexact and reminders fire minutes-to-hours
         late. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Health Connect read permissions for the HealthLearningWorker.
         Each type is a separate runtime permission requested via the
         Health Connect SDK's PermissionController. Off by default;
         the worker silently skips the unavailable types so the user
         can grant whichever subset they're comfortable with. -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_OXYGEN_SATURATION" />
    <uses-permission android:name="android.permission.health.READ_RESPIRATORY_RATE" />
    <uses-permission android:name="android.permission.health.READ_BODY_TEMPERATURE" />
    <uses-permission android:name="android.permission.health.READ_BLOOD_PRESSURE" />
    <uses-permission android:name="android.permission.health.READ_HYDRATION" />

    <!-- Read media images — lets the read_recent_chat_image tool query
         MediaStore for the most-recent image WhatsApp / Telegram / etc.
         auto-saved to the gallery. Useful when notifications surface
         only a tiny thumbnail (or none at all on FLAG_SECURE chats);
         the full-resolution image saved to disk is the only place the
         agent can actually see what was sent. Runtime-granted via the
         standard system prompt. Pre-API-33 the legacy READ_EXTERNAL_
         STORAGE permission below covers the same surface. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Media-location: needed for MediaStore queries to return the
         original EXIF GPS coordinates instead of stripped versions.
         The life-timeline feature uses lat/lng to ground photo
         captions in real places ("at home", "Whole Foods Vancouver")
         via the vision model. Runtime-granted alongside READ_MEDIA_
         IMAGES on Android 10+. Off by default until the user opts in;
         photos without GPS still get captioned, just without place
         context. -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

    <!-- Usage stats — what apps the user has been in, for how long,
         when. Required by the persona-building pipeline that watches
         user behaviour and writes traits into Lumi's memory. Special
         permission, NOT granted via runtime prompt; the user has to
         flip Mythara on in Settings → Apps → Special app access →
         Usage access. Off by default and gated behind an explicit
         Settings toggle inside Mythara on top of that. -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Camera + mic hardware optional (Mythara still useful without them on devices that lack one) -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:name=".MytharaApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.Mythara"
        tools:targetApi="36">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Mythara.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Home / launcher intent. Required to appear in
                 Settings → Apps → Default apps → Home app and be
                 settable as the device's launcher. With this filter
                 present, pressing the home gesture / button brings
                 up Mythara's chat surface (so the assistant IS the
                 home screen). The in-chat app-drawer pill (yellow)
                 fills the role a traditional launcher plays — tap
                 to see installed apps, tap to launch.

                 LAUNCHER is also added below the HOME category so
                 launcher pickers list Mythara explicitly; DEFAULT is
                 needed for the implicit-intent resolution from the
                 home button gesture. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- Digital Assistant intents.
                 When the user sets Mythara as the default assistant app
                 (Settings → Apps → Default apps → Digital assistant app),
                 Android delivers these intents on:
                  - Pixel Buds touch-and-hold (and equivalent on other
                    Google-Assistant-aware earbuds)
                  - Hardware assist button / squeeze gesture
                  - System "assist" gesture (long-press home / corner swipe)
                  - "OK Google" replacement when an alternate assistant is
                    registered (mileage varies per OEM)
                 MainActivity.handleVoiceIntent reads the action, fires
                 VoiceActionStore, and the chat surface kicks off a
                 one-shot SpeechRecognition listen that submits the
                 transcript through the agent loop. -->
            <intent-filter>
                <action android:name="android.intent.action.ASSIST" />
                <action android:name="android.intent.action.VOICE_COMMAND" />
                <action android:name="android.intent.action.WEB_SEARCH" />
                <action android:name="android.intent.action.SEARCH_LONG_PRESS" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Health Connect permissions rationale. Health Connect only
             lists an app in its connected-apps screen — and only lets
             the grant flow complete — when the app declares an activity
             that handles the rationale intent. Without this, Mythara
             has every health.READ_* permission declared above but never
             shows up in the Health Connect app list at all. -->
        <activity
            android:name=".health.HealthRationaleActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Mythara">
            <!-- Health Connect on Android 13 and below (separate APK). -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Health Connect on Android 14+ (baked into the OS) routes the
             privacy-policy / rationale link through VIEW_PERMISSION_USAGE.
             The alias must be guarded by START_VIEW_PERMISSION_USAGE so
             only the system can launch it. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".health.HealthRationaleActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- Observe-mode foreground service (M8.1a heartbeat skeleton;
             AudioRecord + Vosk land in M8.1b). The dual foregroundServiceType
             declares both `microphone` (for the future ASR pipeline) and
             `specialUse` (long-running app-specific use; Android 14+
             requires the explicit subType). -->
        <service
            android:name=".secret.observe.ObserveForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone|specialUse"
            tools:targetApi="34">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="long-running on-device speech observation for personal AI assistant" />
        </service>

        <!-- M5 Notification listener. User grants via Settings →
             Apps → Special app access → Notification access; can't be
             auto-granted by the app. Buffer is in-memory only, never
             persisted. -->
        <service
            android:name=".services.NotificationListener"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- M5 Phone-control Accessibility Service. Bound + driven by
             the system when the user enables it in Settings →
             Accessibility. canRetrieveWindowContent powers `read_screen`;
             canPerformGestures (declared in the xml config) reserves the
             M6 tap/swipe surface so the user only goes through the
             Accessibility settings dance once. -->
        <service
            android:name=".services.PhoneControlAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- VoiceInteractionService — what makes Mythara a real
             "Assistant app" on Android 12+. Required (in addition to
             the ACTION_ASSIST activity intent filter on MainActivity)
             for the home long-press, corner-swipe assist gesture, and
             Pixel Buds touch-and-hold to actually route to us when
             the user picks Mythara in Settings → Default apps →
             Digital assistant app. Without this service the OS lists
             us as a candidate but never delivers the gesture-fired
             intents — only an explicit `am start -a ASSIST` from adb
             would reach MainActivity.

             BIND_VOICE_INTERACTION is the system-protected permission
             that limits binding to the OS itself; the service must
             require it to be accepted as a valid assistant. -->
        <service
            android:name=".voice.MytharaVoiceInteractionService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_VOICE_INTERACTION">
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/voice_interaction_service" />
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
        </service>

        <!-- VoiceInteractionSessionService companion. Required by
             Android to pair with the VoiceInteractionService — our
             stub immediately calls finish() on the session because
             Mythara's UX is the full chat activity, not an overlay
             sheet. -->
        <service
            android:name=".voice.MytharaVoiceInteractionSessionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION" />

        <!-- Stub RecognitionService. Required by Android (current
             Pixel OS) for the VoiceInteractionService registration
             to be considered valid — without it the system rejects
             the assistant selection with "Bad voice interaction
             service: No recognitionService specified" and reverts
             to None. Our stub immediately errors on
             onStartListening so callers fall back to the default
             SpeechRecognizer; Mythara's actual STT path uses
             SpeechRecognizer directly and never touches this. -->
        <service
            android:name=".voice.MytharaRecognitionService"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
            </intent-filter>
            <meta-data
                android:name="android.speech"
                android:resource="@xml/recognition_service" />
        </service>

        <!-- Agent keepalive foreground service. AgentRunner spins this
             up whenever there's active agent work (an in-flight turn,
             a voice trigger, continuous-mic mode). Owns the persistent
             notification + claims an FGS slot so:
              - Android 12+ allows background mic capture for STT /
                continuous-mode / wake-word collectors (microphone type)
              - the OS keeps the Mythara process alive through
                screen-off and recent-apps dismissal long enough for
                the turn to complete and for TTS to finish speaking
              - the user can see Lumi is doing something and tap the
                notification to come back to the chat surface
             AgentRunner stops the service after IDLE_TIMEOUT_MS of no
             active turns so the notification doesn't sit there
             forever when nothing's happening.

             Dual type `microphone|specialUse` — Android 16 tightened
             FGS-type enforcement and throws SecurityException (which
             crashes the process) when starting type=microphone before
             RECORD_AUDIO is runtime-granted. AgentForegroundService
             .startInForeground picks `microphone` when mic is granted,
             `specialUse` otherwise (notification-driven turns that
             don't need to capture audio). -->
        <service
            android:name=".services.AgentForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone|specialUse"
            tools:targetApi="34">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="persistent assistant keepalive for in-flight agent turns" />
        </service>

        <!-- Wear OS push-to-talk listener. The paired Pixel Watch
             runs the wear companion app (separate APK in the :wear
             module); its SpeechRecognizer fires the final transcript
             to this phone over the Wearable Data Layer under
             /mythara/ptt/submit. The service routes the text into
             AgentRunner.submit(fromVoice=true) — same path as the
             in-app mic button, so the agent loop produces a
             voice-friendly short reply that can play through whatever
             BT audio sink is active (often the watch itself). -->
        <service
            android:name=".wear.MytharaWearListenerService"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/mythara/" />
            </intent-filter>
        </service>

        <!-- Lumi always-listen service (M8.3a v2). Foreground service
             of type `microphone` — Vosk runs continuously, each final
             transcript is regex-checked for "Hey Lumi <query>", and on
             match the query is funnelled into ChatViewModel. Single
             AudioRecord client; mutually exclusive with
             ObserveForegroundService at the hardware layer. Mic-only,
             so the LumiListenerService is itself gated on the
             RECORD_AUDIO grant in code — see LumiListenerStore. -->
        <service
            android:name=".wake.LumiListenerService"
            android:exported="false"
            android:foregroundServiceType="microphone"
            tools:targetApi="34" />

        <!-- Notification quick-reply receiver. Catches the
             RemoteInput-driven reply text from the inline-text
             notification action (works on the lockscreen, in the
             shade, AND from Wear OS connected watches) and feeds
             it into AgentRunner.submit — same pipeline as typing
             in the chat composer, without the user ever opening
             the app. -->
        <receiver
            android:name=".agent.NotificationReplyReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.mythara.action.NOTIFICATION_REPLY" />
            </intent-filter>
        </receiver>

        <!-- Reminder alarm receiver. AlarmManager fires this when a
             scheduled task's time arrives; handler announces via TTS,
             posts a notification, and updates the chat scrollback
             with an actionable reminder card (Done / Snooze 15m /
             Snooze 1h). -->
        <receiver
            android:name=".reminders.ReminderAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.mythara.action.REMINDER_FIRE" />
                <action android:name="com.mythara.action.REMINDER_ACTION" />
            </intent-filter>
        </receiver>

        <!-- Boot + app-update receiver. Wakes Mythara's process the
             moment the device finishes booting (or after an app
             update), so the assistant is ready without the user
             having to launch the app first. The receiver itself
             does minimal work — re-posts the QuickTalk notification
             when the toggle is on; everything else (WorkManager
             periodic jobs, accessibility/notification-listener
             auto-rebind, MytharaApp.onCreate's bootstrap hooks) is
             already restart-safe by design. -->
        <receiver
            android:name=".services.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Other services to come:
             * PhoneControlAccessibilityService (M5)
             * NotificationListener (M5)
             * AgentForegroundService (M5+) -->

        <!-- Disable the default androidx.startup WorkManagerInitializer.
             Without this, WorkManager gets initialised with a DEFAULT
             Configuration BEFORE MytharaApp.onCreate runs, which means
             HiltWorkerFactory is never installed and every @HiltWorker
             (MemorySyncWorker, GrowthWorker, HealthLearningWorker,
             SensorLearningWorker, HrCorrelationWorker, LifelineWorker,
             PendingReplyKickWorker, PersonaWorker) silently fails at
             runtime with NoSuchMethodException because the default
             factory reflects for a (Context, WorkerParameters)
             constructor that @AssistedInject workers don't have.
             MytharaApp implements Configuration.Provider so removing
             this initializer lets the Hilt-provided factory take
             effect. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>
</manifest>
