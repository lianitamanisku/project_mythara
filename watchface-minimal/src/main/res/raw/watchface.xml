<?xml version="1.0" encoding="utf-8"?>
<!--
  Mythara MINIMAL — Watch Face Format v2.

  Optimised for battery + glance-readability. Companion to Mythara
  Tactical (the cockpit face); same brand mark, opposite philosophy:
  every pixel earns its place, every animation removed.

  INTERACTIVE:
    • Black background (full-frame OLED off).
    • Mythara rose centred at canvas-upper-third.
    • Time HH:MM in jetbrains_mono_regular below the rose. Large,
      lavender on black for maximum contrast.
    • Compact MYTHARA wordmark below the time.
    • Two complication slots at the bottom: HR (left), battery (right).

  AMBIENT (AOD / power-save):
    • Time HH:MM only, smaller + dimmer (charple instead of lavender)
      so it doesn't dominate at night and OLED burn-in stays low.
    • Rose collapses to a tiny outline above the time.
    • All other elements hidden.

  Structure follows the canonical Tactical-face pattern:
    • Interactive elements wrapped in a <Group name="interactive">
      with `<Variant mode="AMBIENT" target="alpha" value="0" />` —
      proven to actually hide them in ambient (per-element Variant
      on DigitalClock didn't take on Galaxy Watch).
    • Ambient elements wrapped in a <Group name="ambient"> that
      starts at alpha=0 and Variant-flips to 255 in AMBIENT mode.
    • <TimeText> requires a child <Font family="..."> with explicit
      family / size / weight / slant / color — flat color attributes
      are silently ignored.
    • <ComplicationSlot supportedTypes="..."> as XML attribute; each
      type then has its own <Complication type="..."> block plus an
      EMPTY fallback for unbound slots.
-->
<WatchFace width="450" height="450">
    <Metadata key="CLOCK_TYPE" value="DIGITAL" />
    <Metadata key="PREVIEW_TIME" value="10:08:32" />

    <!-- Dot-matrix bitmap font for the AOD — 5×7 cell glyphs, 30×42
         per character. Same font + assets the Tactical face uses for
         its AOD line. Covers digits, colon, plus the letters needed
         for "MYTHARA". -->
    <BitmapFonts>
        <BitmapFont name="dotmatrix">
            <Character name="0" resource="dm_0" width="30" height="42" />
            <Character name="1" resource="dm_1" width="30" height="42" />
            <Character name="2" resource="dm_2" width="30" height="42" />
            <Character name="3" resource="dm_3" width="30" height="42" />
            <Character name="4" resource="dm_4" width="30" height="42" />
            <Character name="5" resource="dm_5" width="30" height="42" />
            <Character name="6" resource="dm_6" width="30" height="42" />
            <Character name="7" resource="dm_7" width="30" height="42" />
            <Character name="8" resource="dm_8" width="30" height="42" />
            <Character name="9" resource="dm_9" width="30" height="42" />
            <Character name=":" resource="dm_colon" width="30" height="42" />
            <Character name="M" resource="dm_m" width="30" height="42" />
            <Character name="Y" resource="dm_y" width="30" height="42" />
            <Character name="T" resource="dm_t" width="30" height="42" />
            <Character name="H" resource="dm_h" width="30" height="42" />
            <Character name="A" resource="dm_a" width="30" height="42" />
            <Character name="R" resource="dm_r" width="30" height="42" />
        </BitmapFont>
    </BitmapFonts>

    <Scene backgroundColor="#ff000000">

        <!-- ============ INTERACTIVE ============ -->
        <Group x="0" y="0" width="450" height="450" name="interactive">
            <Variant mode="AMBIENT" target="alpha" value="0" />

            <!-- Mythara warrior silhouette — subtle purple-tinted
                 figure rendered behind everything else as the very
                 first element of the interactive Group so all other
                 layers sit on top of it. Alpha 60/255 so the
                 presence reads as "there's a guardian behind the
                 brand mark" without ever competing for attention.
                 Hidden in ambient (AOD strips down to bare time +
                 tiny rose outline; no mood backdrop). The PNG is
                 pre-tinted purple and pre-sized 450×450 with the
                 warrior centred vertically (201 px wide × 450 tall). -->
            <PartImage x="0" y="0" width="450" height="450" alpha="90">
                <Image resource="warrior_silhouette" />
            </PartImage>

            <!-- Tick ring — the design intent is a battery gauge
                 (purple = remaining, grey = consumed, with the grey
                 boundary marching anti-clockwise as battery drops).
                 Implementation has the 11 pre-baked battery-level
                 ring variants (tick_marks_b0..tick_marks_b100) ready
                 to go, but WFF v2's [BATTERY.LEVEL] / [BATTERY.PERCENTAGE]
                 system expressions don't appear to be exposed to the
                 watch-face renderer — tactical face only ever reads
                 battery via complications, and our Conditions all
                 evaluated to the 0% bucket (all-grey).
                 Falling back to the always-full purple ring for now;
                 to wire battery later we'd need either a docs-confirmed
                 expression name or a numeric complication (RANGED_VALUE
                 tied to WATCH_BATTERY) plus an [COMPLICATION] sub-
                 expression to read its value. -->
            <PartImage x="0" y="0" width="450" height="450">
                <Image resource="tick_marks_b100" />
            </PartImage>

            <!-- 12 o'clock marker — inverted triangle in the same
                 neon cyan (#68FFD6) as the rose nucleus / time colon
                 / wordmark dots. Apex points DOWN toward the rose;
                 visually replaces the 12-position hour tick and
                 anchors the dial's orientation at a glance. Glow
                 baked into the PNG (Gaussian blur radius 3) for the
                 neon look against OLED black. -->
            <PartImage x="207" y="0" width="36" height="36">
                <Image resource="tick_12" />
            </PartImage>

            <!-- Orbiting neon-red seconds indicator. AnalogClock
                 rotates the SecondHand image around its pivot
                 (bottom-centre of the 44×210 source) once per
                 minute; the visible dot sits 22 px from the image
                 top → orbits at radius 188 from canvas centre,
                 between the rose (radius ~90) and the tick ring
                 (radius 220). Two halos baked into the PNG (Gaussian
                 blur 8 + 3) give the dot a neon-orb feel against
                 OLED black. Inside the interactive Group so the
                 seconds animation is auto-hidden in ambient mode —
                 critical for OLED burn-in + battery. -->
            <AnalogClock x="0" y="0" width="450" height="450">
                <SecondHand resource="seconds_dot"
                    x="203" y="15" width="44" height="210"
                    pivotX="0.5" pivotY="1.0" />
            </AnalogClock>

            <!-- Brand mark: 130×130 rose centred horizontally in the
                 upper third of the face. Smaller than before to leave
                 room for the ECG/HR row below the wordmark. Tapping
                 it launches the Mythara wear app (PTT-first home). -->
            <PartImage x="160" y="45" width="130" height="130">
                <Launch target="com.mythara.debug/com.mythara.wear.MainActivity" />
                <Image resource="rose" />
            </PartImage>

            <!-- Day + date row, between the rose and the time. Three
                 PartText elements with Template/Parameter expressions
                 driving the dynamic strings — WFF's TimeText format
                 attribute apparently only handles HH/mm tokens, but
                 the Template/Parameter pattern (proven to work on
                 complication text) interpolates date fields via
                 typed parameter expressions.
                   • Day abbreviation (e.g. "SAT") — purple.
                   • " | " pipe — neon cyan (same #68FFD6 as the
                     rose nucleus / time colon).
                   • "MAY 16" date — purple.
                 The day name uses [DAY_OF_WEEK_S] (short form,
                 single-line), month uses [MONTH_S], day-of-month
                 uses [DAY] — all are standard WFF template
                 parameters listed in the format reference. -->
            <PartText x="115" y="190" width="100" height="22">
                <Text align="END">
                    <Font family="jetbrains_mono_regular" size="15"
                        weight="BOLD" slant="NORMAL" color="#ff9b86ff">
                        <Template><![CDATA[%s]]><Parameter expression="[DAY_OF_WEEK_S]" /></Template>
                    </Font>
                </Text>
            </PartText>
            <PartText x="215" y="190" width="20" height="22">
                <Text align="CENTER">
                    <Font family="jetbrains_mono_regular" size="16"
                        weight="BOLD" slant="NORMAL"
                        color="#ff68ffd6"><![CDATA[|]]></Font>
                </Text>
            </PartText>
            <PartText x="235" y="190" width="100" height="22">
                <Text align="START">
                    <Font family="jetbrains_mono_regular" size="15"
                        weight="BOLD" slant="NORMAL" color="#ff9b86ff">
                        <Template><![CDATA[%s %d]]><Parameter expression="[MONTH_S]" /><Parameter expression="[DAY]" /></Template>
                    </Font>
                </Text>
            </PartText>

            <!-- Time HH:MM — split into 3 columns so each piece gets
                 its own colour: hours in neon purple, colon in neon
                 cyan, minutes in neon purple. Moved down to y=255 to
                 make room for the day/date row above. -->
            <DigitalClock x="99" y="220" width="100" height="80">
                <TimeText format="hh" hourFormat="24" align="END"
                    x="0" y="0" width="100" height="80">
                    <Font family="jetbrains_mono_regular" size="56"
                        weight="NORMAL" slant="NORMAL" color="#ff9b86ff" />
                </TimeText>
            </DigitalClock>
            <PartText x="199" y="220" width="52" height="80">
                <Text align="CENTER">
                    <Font family="jetbrains_mono_regular" size="56"
                        weight="NORMAL" slant="NORMAL"
                        color="#ff68ffd6"><![CDATA[:]]></Font>
                </Text>
            </PartText>
            <DigitalClock x="251" y="220" width="100" height="80">
                <TimeText format="mm" align="START"
                    x="0" y="0" width="100" height="80">
                    <Font family="jetbrains_mono_regular" size="56"
                        weight="NORMAL" slant="NORMAL" color="#ff9b86ff" />
                </TimeText>
            </DigitalClock>

            <!-- Stylised M.Y.T.H.A.R.A wordmark beneath the time —
                 letters in purple (matches the wear app's letters)
                 with neon-cyan dots between them (matches the rose
                 hex nucleus + the time colon above). Multiple <Font>
                 children inside a single <Text> let each glyph carry
                 its own colour without needing 13 separately-
                 positioned PartText elements. Moved down to y=340
                 to follow the time's relocation (made room for the
                 day/date row above). -->
            <PartText x="0" y="305" width="450" height="24">
                <Text align="CENTER">
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff9b86ff"><![CDATA[M]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff68ffd6"><![CDATA[.]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff9b86ff"><![CDATA[Y]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff68ffd6"><![CDATA[.]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff9b86ff"><![CDATA[T]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff68ffd6"><![CDATA[.]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff9b86ff"><![CDATA[H]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff68ffd6"><![CDATA[.]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff9b86ff"><![CDATA[A]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff68ffd6"><![CDATA[.]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff9b86ff"><![CDATA[R]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff68ffd6"><![CDATA[.]]></Font>
                    <Font family="jetbrains_mono_regular" size="14" weight="BOLD" color="#ff9b86ff"><![CDATA[A]]></Font>
                </Text>
            </PartText>

            <!-- ECG strip — subtle purple QRS-T waveform with a baked-
                 in sweep gradient. -->
            <PartImage x="115" y="340" width="220" height="24">
                <Image resource="ecg_wave" />
            </PartImage>

            <!-- HR value beneath the ECG strip — pulled from the
                 HEART_RATE complication provider. -->
            <ComplicationSlot slotId="1" x="175" y="370" width="100" height="26"
                supportedTypes="SHORT_TEXT EMPTY">
                <BoundingOval x="0" y="0" width="100" height="26" />
                <DefaultProviderPolicy
                    defaultSystemProvider="HEART_RATE"
                    defaultSystemProviderType="SHORT_TEXT" />
                <Complication type="SHORT_TEXT">
                    <PartText x="0" y="0" width="100" height="26">
                        <Text align="CENTER">
                            <Font family="jetbrains_mono_regular" size="16"
                                weight="NORMAL" slant="NORMAL" color="#ff9b86ff">
                                <Template><![CDATA[%s bpm]]><Parameter expression="[COMPLICATION.TEXT]" /></Template>
                            </Font>
                        </Text>
                    </PartText>
                </Complication>
                <Complication type="EMPTY" />
            </ComplicationSlot>

            <!-- Battery complication (slot 2) — kept so WFF doesn't
                 reject the schema. Rendered tiny in the top-right,
                 effectively invisible at low alpha. WFF v2 seems to
                 require sequential slotIds (1 + 2); removing slot 2
                 caused the whole face to fail style-schema extraction
                 with FavoriteOperationException Error 0. -->
            <ComplicationSlot slotId="2" x="0" y="0" width="1" height="1"
                supportedTypes="SHORT_TEXT EMPTY">
                <BoundingOval x="0" y="0" width="1" height="1" />
                <DefaultProviderPolicy
                    defaultSystemProvider="WATCH_BATTERY"
                    defaultSystemProviderType="SHORT_TEXT" />
                <Complication type="EMPTY" />
                <Complication type="SHORT_TEXT" />
            </ComplicationSlot>
        </Group>

        <!-- ============ AMBIENT (AOD) ============ -->
        <!-- MYTHARA wordmark + rose + time + day/date — all minimal
             elements for OLED-burn-in / battery. Dot-matrix bitmap
             font uses the SAME size as the tactical face (30) for the
             time + wordmark — sizes 20 / 38 in the previous attempt
             broke the WFF parser. -->
        <Group x="0" y="0" width="450" height="450" name="ambient" alpha="0">
            <Variant mode="AMBIENT" target="alpha" value="255" />

            <!-- MYTHARA wordmark — dot-matrix, dim purple. Size 30
                 matches the bitmap font's character cell (proven
                 in the tactical face's AOD). -->
            <PartText x="0" y="80" width="450" height="42">
                <Text align="CENTER">
                    <BitmapFont family="dotmatrix" size="30" color="#ff8a6fff"><![CDATA[MYTHARA]]></BitmapFont>
                </Text>
            </PartText>

            <!-- Rose — small, centred just below the wordmark. -->
            <PartImage x="195" y="138" width="60" height="60">
                <Image resource="rose" />
            </PartImage>

            <!-- Time HH:MM — dot-matrix purple, size 30 (matches
                 cell size). -->
            <DigitalClock x="0" y="218" width="450" height="58">
                <TimeText format="hh:mm" hourFormat="24" align="CENTER"
                    x="0" y="0" width="450" height="58">
                    <BitmapFont family="dotmatrix" size="30" color="#ff8a6fff" />
                </TimeText>
            </DigitalClock>

            <!-- Day | Date row — small text under the time. Uses
                 jetbrains_mono_regular because dot-matrix font lacks
                 the full alphabet for day names + month abbreviations.
                 Same lavender purple as the wordmark for visual
                 cohesion. -->
            <PartText x="100" y="290" width="120" height="22">
                <Text align="END">
                    <Font family="jetbrains_mono_regular" size="14"
                        weight="BOLD" slant="NORMAL" color="#ff8a6fff">
                        <Template><![CDATA[%s]]><Parameter expression="[DAY_OF_WEEK_S]" /></Template>
                    </Font>
                </Text>
            </PartText>
            <PartText x="215" y="290" width="20" height="22">
                <Text align="CENTER">
                    <Font family="jetbrains_mono_regular" size="14"
                        weight="BOLD" slant="NORMAL" color="#ff8a6fff"><![CDATA[|]]></Font>
                </Text>
            </PartText>
            <PartText x="230" y="290" width="120" height="22">
                <Text align="START">
                    <Font family="jetbrains_mono_regular" size="14"
                        weight="BOLD" slant="NORMAL" color="#ff8a6fff">
                        <Template><![CDATA[%s %d]]><Parameter expression="[MONTH_S]" /><Parameter expression="[DAY]" /></Template>
                    </Font>
                </Text>
            </PartText>
        </Group>
    </Scene>
</WatchFace>
